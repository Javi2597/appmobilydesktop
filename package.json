{
  "name": "appmobilydesktop",
  "version": "1.0.2",
  "description": "Visor de URLs con vista móvil + escritorio en paralelo para grabar contenido",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node scripts/generate-icon.mjs",
    "dist": "electron-builder --win --publish never",
    "release": "electron-builder --win --publish always"
  },
  "keywords": [
    "electron",
    "webview",
    "responsive",
    "preview"
  ],
  "author": "Javi2597",
  "license": "MIT",
  "build": {
    "appId": "com.javi2597.appmobilydesktop",
    "productName": "Mobile Desktop Viewer",
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "package.json",
      "build/icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Javi2597",
      "repo": "appmobilydesktop"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ],
    "ignoredBuiltDependencies": [
      "electron-winstaller"
    ]
  }
}
